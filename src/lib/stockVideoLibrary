// Helper function to generate video metadata
export function generateVideoMetadata(category, index, source) {
  const authors = {
    pexels: ['Pexels Creator', 'Stock Video Pro', 'Content Creator', 'Video Artist'],
    pixabay: ['Pixabay User', 'Free Stock Videos', 'Video Library', 'Media Creator'],
    mixkit: ['Mixkit Artist', 'Professional Videos', 'Studio Creator', 'Video Producer'],
  };
  
  const authorName = authors[source][index % authors[source].length];
  const username = `${source}_${category}_${index}`;
  
  return {
    author_name: authorName,
    author_username: username,
  };
}

